#!/usr/bin/env bash
set -Eeuo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ENV_FILE="${ENV_FILE:-$ROOT_DIR/.env}"
RELEASE_VERSION_OVERRIDE="${1:-${RELEASE_VERSION:-}}"

# shellcheck source=../scripts/lib/env.sh
source "$ROOT_DIR/scripts/lib/env.sh"
load_env_file "$ENV_FILE"

require_command kubectl
require_command helm
require_env \
  HARBOR_REGISTRY HARBOR_PROJECT HARBOR_REPOSITORY \
  KUBE_CONFIG KUBE_NAMESPACE HELM_RELEASE HELM_CHART HELM_TIMEOUT \
  HELM_ATOMIC HELM_CREATE_NAMESPACE DEPLOY_REPLICAS DEPLOY_CONTAINER_PORT \
  DEPLOY_SERVICE_PORT DEPLOY_IMAGE_PULL_POLICY DEPLOY_IMAGE_PULL_SECRET \
  DEPLOY_CREATE_IMAGE_PULL_SECRET DEPLOY_MAX_SURGE DEPLOY_MAX_UNAVAILABLE \
  DEPLOY_HEALTH_PATH DEPLOY_ROLLOUT_TIMEOUT DEPLOY_PDB_ENABLED \
  DEPLOY_PDB_MIN_AVAILABLE DEPLOY_HOST DEPLOY_APISIX_INGRESS_CLASS \
  DEPLOY_APISIX_ROUTE_NAME DEPLOY_APISIX_TLS_NAME DEPLOY_APISIX_PATH \
  DEPLOY_HTTP_TO_HTTPS DEPLOY_CERTIFICATE_ENABLED DEPLOY_CERTIFICATE_NAME \
  DEPLOY_CERTIFICATE_SECRET DEPLOY_CERTIFICATE_ISSUER \
  DEPLOY_CERTIFICATE_ISSUER_KIND DEPLOY_CERTIFICATE_ISSUER_GROUP \
  DEPLOY_CERTIFICATE_DURATION DEPLOY_CERTIFICATE_RENEW_BEFORE \
  DEPLOY_WAIT_CERTIFICATE DEPLOY_CERTIFICATE_TIMEOUT DEPLOY_VERIFY_HTTPS \
  DEPLOY_VERIFY_HTTP_REDIRECT DEPLOY_VERIFY_ATTEMPTS \
  DEPLOY_VERIFY_INTERVAL_SECONDS DEPLOY_VERIFY_TIMEOUT_SECONDS

APP_VERSION="$RELEASE_VERSION_OVERRIDE"
if [[ ! "$APP_VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  printf 'Usage: %s <semantic-version>\n' "$0" >&2
  printf 'Computed application version is not semantic: %s\n' "${APP_VERSION:-<empty>}" >&2
  exit 1
fi

validate_int_or_percent() {
  local variable_name="$1"
  local value="$2"

  if [[ "$value" =~ ^[0-9]+$ ]] || [[ "$value" =~ ^([0-9]|[1-9][0-9]|100)%$ ]]; then
    return 0
  fi

  printf '%s must be a non-negative integer or a percentage from 0%% to 100%%; got: %s\n' \
    "$variable_name" "$value" >&2
  exit 1
}

is_zero_int_or_percent() {
  [[ "$1" == "0" || "$1" == "0%" ]]
}

validate_int_or_percent DEPLOY_MAX_SURGE "$DEPLOY_MAX_SURGE"
validate_int_or_percent DEPLOY_MAX_UNAVAILABLE "$DEPLOY_MAX_UNAVAILABLE"
if is_zero_int_or_percent "$DEPLOY_MAX_SURGE" && is_zero_int_or_percent "$DEPLOY_MAX_UNAVAILABLE"; then
  printf 'DEPLOY_MAX_SURGE and DEPLOY_MAX_UNAVAILABLE cannot both be zero.\n' >&2
  exit 1
fi

IMAGE_REPOSITORY="${HARBOR_REGISTRY}/${HARBOR_PROJECT}/${HARBOR_REPOSITORY}"
CHART_PATH="$ROOT_DIR/$HELM_CHART"

if [[ ! -d "$CHART_PATH" ]]; then
  printf 'Helm chart not found: %s\n' "$CHART_PATH" >&2
  exit 1
fi

KUBECTL=(kubectl --kubeconfig "$KUBE_CONFIG")
HELM=(helm --kubeconfig "$KUBE_CONFIG")
if [[ -n "${KUBE_CONTEXT:-}" ]]; then
  KUBECTL+=(--context "$KUBE_CONTEXT")
  HELM+=(--kube-context "$KUBE_CONTEXT")
fi

require_crd() {
  local crd_name="$1"
  local resource_label="$2"
  if ! "${KUBECTL[@]}" get crd "$crd_name" >/dev/null 2>&1; then
    printf 'Required %s CRD is unavailable: %s\n' "$resource_label" "$crd_name" >&2
    exit 1
  fi
}

printf '==> Deploying release %s\n' "$APP_VERSION"
printf '==> Configuration: %s\n' "$ENV_FILE"
printf '==> Deploying %s:%s\n' "$IMAGE_REPOSITORY" "$APP_VERSION"
printf '==> Helm release: %s\n' "$HELM_RELEASE"
printf '==> Namespace: %s\n' "$KUBE_NAMESPACE"
printf '==> HTTPS host: %s\n' "$DEPLOY_HOST"

# Use the same cluster prerequisites as the Small Project deployment.
require_crd apisixroutes.apisix.apache.org ApisixRoute
require_crd apisixtlses.apisix.apache.org ApisixTls
"${KUBECTL[@]}" get ingressclass "$DEPLOY_APISIX_INGRESS_CLASS" >/dev/null
if is_true "$DEPLOY_CERTIFICATE_ENABLED"; then
  require_crd certificates.cert-manager.io Certificate
  if [[ "$DEPLOY_CERTIFICATE_ISSUER_KIND" == "ClusterIssuer" ]]; then
    "${KUBECTL[@]}" get clusterissuer "$DEPLOY_CERTIFICATE_ISSUER" >/dev/null
    "${KUBECTL[@]}" wait --for=condition=Ready \
      "clusterissuer/$DEPLOY_CERTIFICATE_ISSUER" \
      --timeout="$DEPLOY_CERTIFICATE_TIMEOUT"
  fi
fi

if is_true "$HELM_CREATE_NAMESPACE"; then
  "${KUBECTL[@]}" create namespace "$KUBE_NAMESPACE" --dry-run=client -o yaml | \
    "${KUBECTL[@]}" apply -f -
else
  "${KUBECTL[@]}" get namespace "$KUBE_NAMESPACE" >/dev/null
fi

if is_true "$DEPLOY_CERTIFICATE_ENABLED" && [[ "$DEPLOY_CERTIFICATE_ISSUER_KIND" != "ClusterIssuer" ]]; then
  "${KUBECTL[@]}" -n "$KUBE_NAMESPACE" get issuer "$DEPLOY_CERTIFICATE_ISSUER" >/dev/null
  "${KUBECTL[@]}" -n "$KUBE_NAMESPACE" wait --for=condition=Ready \
    "issuer/$DEPLOY_CERTIFICATE_ISSUER" \
    --timeout="$DEPLOY_CERTIFICATE_TIMEOUT"
fi

if is_true "$DEPLOY_CREATE_IMAGE_PULL_SECRET"; then
  require_env HARBOR_USERNAME HARBOR_PASSWORD HARBOR_EMAIL
  "${KUBECTL[@]}" -n "$KUBE_NAMESPACE" create secret docker-registry "$DEPLOY_IMAGE_PULL_SECRET" \
    --docker-server="$HARBOR_REGISTRY" \
    --docker-username="$HARBOR_USERNAME" \
    --docker-password="$HARBOR_PASSWORD" \
    --docker-email="$HARBOR_EMAIL" \
    --dry-run=client -o yaml | "${KUBECTL[@]}" apply -f -
fi

HELM_VALUE_ARGS=(
  --set-string "image.repository=$IMAGE_REPOSITORY"
  --set-string "image.tag=$APP_VERSION"
  --set-string "image.pullPolicy=$DEPLOY_IMAGE_PULL_POLICY"
  --set-string "imagePullSecrets[0].name=$DEPLOY_IMAGE_PULL_SECRET"
  --set "replicaCount=$DEPLOY_REPLICAS"
  --set "containerPort=$DEPLOY_CONTAINER_PORT"
  --set "service.port=$DEPLOY_SERVICE_PORT"
  --set "strategy.maxSurge=$DEPLOY_MAX_SURGE"
  --set "strategy.maxUnavailable=$DEPLOY_MAX_UNAVAILABLE"
  --set-string "health.path=$DEPLOY_HEALTH_PATH"
  --set "podDisruptionBudget.enabled=$DEPLOY_PDB_ENABLED"
  --set "podDisruptionBudget.minAvailable=$DEPLOY_PDB_MIN_AVAILABLE"
  --set "apisix.enabled=true"
  --set-string "apisix.ingressClassName=$DEPLOY_APISIX_INGRESS_CLASS"
  --set-string "apisix.routeName=$DEPLOY_APISIX_ROUTE_NAME"
  --set-string "apisix.tlsName=$DEPLOY_APISIX_TLS_NAME"
  --set-string "apisix.host=$DEPLOY_HOST"
  --set-string "apisix.path=$DEPLOY_APISIX_PATH"
  --set "apisix.httpToHttps=$DEPLOY_HTTP_TO_HTTPS"
  --set "certificate.enabled=$DEPLOY_CERTIFICATE_ENABLED"
  --set-string "certificate.name=$DEPLOY_CERTIFICATE_NAME"
  --set-string "certificate.secretName=$DEPLOY_CERTIFICATE_SECRET"
  --set-string "certificate.issuerRef.name=$DEPLOY_CERTIFICATE_ISSUER"
  --set-string "certificate.issuerRef.kind=$DEPLOY_CERTIFICATE_ISSUER_KIND"
  --set-string "certificate.issuerRef.group=$DEPLOY_CERTIFICATE_ISSUER_GROUP"
  --set-string "certificate.duration=$DEPLOY_CERTIFICATE_DURATION"
  --set-string "certificate.renewBefore=$DEPLOY_CERTIFICATE_RENEW_BEFORE"
)

"${HELM[@]}" template "$HELM_RELEASE" "$CHART_PATH" \
  --namespace "$KUBE_NAMESPACE" \
  "${HELM_VALUE_ARGS[@]}" >/dev/null

HELM_UPGRADE_ARGS=(
  upgrade --install "$HELM_RELEASE" "$CHART_PATH"
  --namespace "$KUBE_NAMESPACE"
  --wait
  --timeout "$HELM_TIMEOUT"
  "${HELM_VALUE_ARGS[@]}"
)
if is_true "$HELM_ATOMIC"; then
  HELM_UPGRADE_ARGS+=(--atomic)
fi

"${HELM[@]}" "${HELM_UPGRADE_ARGS[@]}"

"${KUBECTL[@]}" -n "$KUBE_NAMESPACE" rollout status \
  "deployment/$HELM_RELEASE" --timeout="$DEPLOY_ROLLOUT_TIMEOUT"
"${KUBECTL[@]}" -n "$KUBE_NAMESPACE" get apisixroute "$DEPLOY_APISIX_ROUTE_NAME" >/dev/null
"${KUBECTL[@]}" -n "$KUBE_NAMESPACE" get apisixtls "$DEPLOY_APISIX_TLS_NAME" >/dev/null

if is_true "$DEPLOY_CERTIFICATE_ENABLED" && is_true "$DEPLOY_WAIT_CERTIFICATE"; then
  "${KUBECTL[@]}" -n "$KUBE_NAMESPACE" wait \
    --for=condition=Ready "certificate/$DEPLOY_CERTIFICATE_NAME" \
    --timeout="$DEPLOY_CERTIFICATE_TIMEOUT"
fi

verify_with_retry() {
  local label="$1"
  shift
  local attempt
  for (( attempt=1; attempt<=DEPLOY_VERIFY_ATTEMPTS; attempt++ )); do
    if "$@"; then
      printf '%s verified on attempt %d.\n' "$label" "$attempt"
      return 0
    fi
    sleep "$DEPLOY_VERIFY_INTERVAL_SECONDS"
  done
  printf '%s verification failed after %s attempts.\n' "$label" "$DEPLOY_VERIFY_ATTEMPTS" >&2
  return 1
}

if is_true "$DEPLOY_VERIFY_HTTPS"; then
  require_command curl
  verify_with_retry "HTTPS endpoint" \
    curl --fail --silent --show-error --max-time "$DEPLOY_VERIFY_TIMEOUT_SECONDS" \
    "https://${DEPLOY_HOST}${DEPLOY_HEALTH_PATH}" >/dev/null
fi

if is_true "$DEPLOY_VERIFY_HTTP_REDIRECT"; then
  require_command curl
  verify_http_redirect() {
    local headers
    headers="$(curl --silent --show-error --head --max-time "$DEPLOY_VERIFY_TIMEOUT_SECONDS" \
      "http://${DEPLOY_HOST}${DEPLOY_HEALTH_PATH}")" || return 1
    grep -Eq '^HTTP/[0-9.]+ (301|302|307|308)' <<<"$headers" && \
      grep -Eiq "^location: https://${DEPLOY_HOST}" <<<"$headers"
  }
  verify_with_retry "HTTP to HTTPS redirect" verify_http_redirect
fi

printf 'Deployment complete: https://%s (image %s:%s)\n' \
  "$DEPLOY_HOST" "$IMAGE_REPOSITORY" "$APP_VERSION"
