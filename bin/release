#!/usr/bin/env bash
set -Eeuo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"
ENV_FILE="${ENV_FILE:-$ROOT_DIR/.env}"

usage() {
  cat <<'USAGE'
Usage: bin/release --patch|--minor|--major [options]

Create the next stable version from Git tags, build and push its Harbor image,
deploy it with the Small Project Helm process, then publish the Git tag.

Options:
  --patch          Increment the patch version.
  --minor          Increment the minor version.
  --major          Increment the major version.
  --dry-run        Print actions without changing Git, Harbor or Kubernetes.
  --skip-latest    Do not publish the mutable :latest image tag.
  --skip-deploy    Build and publish the release without deploying it.
  -h, --help       Show this help.
USAGE
}

# shellcheck source=../scripts/lib/env.sh
source "$ROOT_DIR/scripts/lib/env.sh"

is_stable_tag() {
  [[ "$1" =~ ^v?[0-9]+\.[0-9]+\.[0-9]+$ ]]
}

normalize_version() {
  printf '%s\n' "${1#v}"
}

latest_stable_version() {
  local tag
  while IFS= read -r tag; do
    if is_stable_tag "$tag"; then
      normalize_version "$tag"
    fi
  done < <(git tag --list) | sort -V | tail -n 1
}

next_version() {
  local current="$1"
  local bump="$2"
  local major minor patch

  if [[ -z "$current" ]]; then
    printf '0.1.0\n'
    return
  fi

  IFS=. read -r major minor patch <<<"$current"
  case "$bump" in
    patch) printf '%d.%d.%d\n' "$major" "$minor" "$((patch + 1))" ;;
    minor) printf '%d.%d.0\n' "$major" "$((minor + 1))" ;;
    major) printf '%d.0.0\n' "$((major + 1))" ;;
    *) printf 'Unsupported bump type: %s\n' "$bump" >&2; return 1 ;;
  esac
}

detect_git_remote() {
  local branch branch_remote
  local -a remotes=()

  if git remote get-url origin >/dev/null 2>&1; then
    printf 'origin\n'
    return
  fi

  branch="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
  if [[ -n "$branch" ]]; then
    branch_remote="$(git config --get "branch.${branch}.remote" 2>/dev/null || true)"
    if [[ -n "$branch_remote" && "$branch_remote" != '.' ]] && \
      git remote get-url "$branch_remote" >/dev/null 2>&1; then
      printf '%s\n' "$branch_remote"
      return
    fi
  fi

  mapfile -t remotes < <(git remote)
  if (( ${#remotes[@]} == 1 )); then
    printf '%s\n' "${remotes[0]}"
    return
  fi

  if (( ${#remotes[@]} == 0 )); then
    printf 'No Git remote is configured. Add a remote, preferably named origin.\n' >&2
  else
    printf 'Unable to choose a Git remote automatically. Configure origin or a tracking remote.\n' >&2
  fi
  return 1
}

RELEASE_TYPE=''
dry_run=false
skip_latest=false
skip_deploy=false

while (( $# > 0 )); do
  case "$1" in
    --patch|--minor|--major)
      [[ -z "$RELEASE_TYPE" ]] || { printf 'Choose exactly one version increment.\n' >&2; exit 1; }
      RELEASE_TYPE="${1#--}"
      ;;
    --dry-run) dry_run=true ;;
    --skip-latest) skip_latest=true ;;
    --skip-deploy) skip_deploy=true ;;
    -h|--help) usage; exit 0 ;;
    *) printf 'Unknown option: %s\n' "$1" >&2; usage >&2; exit 1 ;;
  esac
  shift
done

[[ -n "$RELEASE_TYPE" ]] || { usage >&2; exit 1; }

load_env_file "$ENV_FILE"
require_command git
require_env \
  APP_NAME PUBLIC_SITE_URL DOCKERFILE DOCKER_BUILD_CONTEXT DOCKER_PLATFORM \
  HARBOR_REGISTRY HARBOR_PROJECT HARBOR_REPOSITORY HARBOR_LOGIN \
  HARBOR_PUSH_LATEST HELM_CHART

CHART_PATH="$ROOT_DIR/$HELM_CHART"
if [[ ! -d "$CHART_PATH" ]]; then
  printf 'Helm chart not found: %s\n' "$CHART_PATH" >&2
  exit 1
fi

if [[ "$dry_run" == false ]]; then
  require_command docker
  require_command helm
  helm lint "$CHART_PATH"
fi

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  printf 'The project is not inside a Git repository.\n' >&2
  exit 1
fi
if [[ -n "$(git status --porcelain --untracked-files=normal)" ]]; then
  printf 'Git working tree must be clean before release.\n' >&2
  exit 1
fi

GIT_REMOTE="$(detect_git_remote)"
if [[ "$dry_run" == false ]]; then
  printf '==> Fetching tags from %s\n' "$GIT_REMOTE"
  git fetch --tags --force "$GIT_REMOTE"
fi

CURRENT_VERSION="$(latest_stable_version)"
NEXT_VERSION="$(next_version "$CURRENT_VERSION" "$RELEASE_TYPE")"
TAG_NAME="$NEXT_VERSION"
IMAGE_REPOSITORY="${HARBOR_REGISTRY}/${HARBOR_PROJECT}/${HARBOR_REPOSITORY}"
IMAGE_VERSION="${IMAGE_REPOSITORY}:${NEXT_VERSION}"
LATEST_IMAGE="${IMAGE_REPOSITORY}:latest"
REVISION="$(git rev-parse HEAD)"
BUILD_DATE="$(date -u +'%Y-%m-%dT%H:%M:%SZ')"

if git rev-parse "$TAG_NAME" >/dev/null 2>&1; then
  printf 'Git tag already exists: %s\n' "$TAG_NAME" >&2
  exit 1
fi

printf '==> Configuration: %s\n' "$ENV_FILE"
printf '==> Current stable version: %s\n' "${CURRENT_VERSION:-none}"
printf '==> Next version: %s\n' "$NEXT_VERSION"
printf '==> Harbor image: %s\n' "$IMAGE_VERSION"

PUSH_LATEST=false
if is_true "$HARBOR_PUSH_LATEST" && [[ "$skip_latest" == false ]]; then
  PUSH_LATEST=true
fi

if [[ "$dry_run" == true ]]; then
  if is_true "$HARBOR_LOGIN"; then
    printf '==> Would authenticate to %s using .env credentials\n' "$HARBOR_REGISTRY"
  else
    printf '==> Would use the existing Docker authentication for %s\n' "$HARBOR_REGISTRY"
  fi
  printf '==> Would build and push %s\n' "$IMAGE_VERSION"
  [[ "$PUSH_LATEST" == true ]] && printf '==> Would push %s\n' "$LATEST_IMAGE"
  [[ "$skip_deploy" == false ]] && printf '==> Would deploy %s before publishing the Git tag\n' "$NEXT_VERSION"
  printf '==> Would create and push Git tag %s to %s\n' "$TAG_NAME" "$GIT_REMOTE"
  exit 0
fi

if is_true "$HARBOR_LOGIN"; then
  require_env HARBOR_USERNAME HARBOR_PASSWORD
  printf '==> Authenticating to Harbor registry %s\n' "$HARBOR_REGISTRY"
  printf '%s' "$HARBOR_PASSWORD" | docker login "$HARBOR_REGISTRY" \
    --username "$HARBOR_USERNAME" --password-stdin
fi

BUILD_ARGS=(
  --pull
  --platform "$DOCKER_PLATFORM"
  --file "$DOCKERFILE"
  --build-arg "VERSION=$NEXT_VERSION"
  --build-arg "VCS_REF=$REVISION"
  --build-arg "BUILD_DATE=$BUILD_DATE"
  --build-arg "PUBLIC_SITE_URL=$PUBLIC_SITE_URL"
  --label "org.opencontainers.image.title=$APP_NAME"
  --label "org.opencontainers.image.version=$NEXT_VERSION"
  --label "org.opencontainers.image.revision=$REVISION"
  --tag "$IMAGE_VERSION"
)
if [[ -n "${DOCKER_BUILD_ARGS:-}" ]]; then
  # Intentional shell splitting: this variable contains Docker CLI options.
  # shellcheck disable=SC2206
  EXTRA_BUILD_ARGS=( ${DOCKER_BUILD_ARGS} )
  BUILD_ARGS+=("${EXTRA_BUILD_ARGS[@]}")
fi
BUILD_ARGS+=("$DOCKER_BUILD_CONTEXT")

docker build "${BUILD_ARGS[@]}"
docker push "$IMAGE_VERSION"
if [[ "$PUSH_LATEST" == true ]]; then
  docker tag "$IMAGE_VERSION" "$LATEST_IMAGE"
  docker push "$LATEST_IMAGE"
fi

# Match the Small Project process: deployment must succeed before the Git tag
# is published, preventing failed deployments from consuming a release number.
if [[ "$skip_deploy" == false ]]; then
  RELEASE_VERSION="$NEXT_VERSION" ENV_FILE="$ENV_FILE" "$ROOT_DIR/bin/deploy"
fi

TAG_CREATED=false
cleanup_failed_tag() {
  local exit_code=$?
  if (( exit_code != 0 )) && [[ "$TAG_CREATED" == true ]]; then
    git tag -d "$TAG_NAME" >/dev/null 2>&1 || true
    printf 'Local tag %s removed because it could not be published.\n' "$TAG_NAME" >&2
  fi
  exit "$exit_code"
}
trap cleanup_failed_tag EXIT

git tag -a "$TAG_NAME" -m "Release $TAG_NAME"
TAG_CREATED=true
git push "$GIT_REMOTE" "$TAG_NAME"

trap - EXIT
printf 'Release %s completed and deployed.\n' "$NEXT_VERSION"
